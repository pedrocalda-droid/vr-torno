<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AR Real - Torno Mecânico Inspeção Estável</title>
    <style>
        :root {
            --bg-color: #1e1e1e;
            --panel-bg: #2d2d2d;
            --text-color: #ffffff;
            --lube-color: #00b4d8;
            --maint-color: #ffb703;
            --info-color: #9b5de5;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
        }

        .container { max-width: 800px; width: 100%; }

        .controls {
            display: flex; gap: 15px; margin-bottom: 20px;
            justify-content: center; position: relative; z-index: 200;
        }

        button {
            padding: 12px 20px; font-size: 16px; font-weight: bold;
            border: 2px solid #555; background-color: var(--panel-bg);
            color: var(--text-color); border-radius: 8px;
            cursor: pointer; transition: all 0.3s ease;
        }

        button.active[data-mode="interesse"] { background-color: var(--info-color); border-color: var(--info-color); color: #fff; }
        button.active[data-mode="lubrificacao"] { background-color: var(--lube-color); border-color: var(--lube-color); color: #000; }
        button.active[data-mode="manutencao"] { background-color: var(--maint-color); border-color: var(--maint-color); color: #000; }

        .action-buttons {
            display: flex; justify-content: center; gap: 10px;
            margin-bottom: 15px; z-index: 10; position: relative; flex-wrap: wrap;
        }

        .btn-action { font-size: 14px; padding: 10px 15px; display: flex; align-items: center; gap: 8px; }

        .camera-view {
            position: relative; width: 100%; height: 450px;
            background-color: #000; border-radius: 12px; overflow: hidden;
            border: 2px solid #444;
        }

        #webcam {
            width: 100%; height: 100%; object-fit: cover;
            position: absolute; top: 0; left: 0; z-index: 1;
        }

        #foto-estatica {
            display: none; width: 100%; height: 100%; object-fit: cover;
            position: absolute; top: 0; left: 0; z-index: 1;
        }

        /* Pontos totalmente fixos com transform translate simples */
        .hotspot {
            position: absolute;
            width: 36px; height: 36px; border-radius: 50%;
            transform: translate(-50%, -50%);
            cursor: grab; display: none; 
            box-shadow: 0 4px 8px rgba(0,0,0,0.5), 0 0 0 rgba(255, 255, 255, 0.4);
            animation: pulse 1.5s infinite; border: 2px solid white;
            z-index: 100;
            justify-content: center; align-items: center;
            font-size: 18px; text-shadow: 0 2px 4px rgba(0,0,0,0.5);
            user-select: none;
        }

        .hotspot:active { cursor: grabbing; }
        .hotspot[data-type="interesse"] { background-color: var(--info-color); }
        .hotspot[data-type="lubrificacao"] { background-color: var(--lube-color); }
        .hotspot[data-type="manutencao"] { background-color: var(--maint-color); }
        .hotspot.visible { display: flex; }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7); }
            70% { box-shadow: 0 0 0 15px rgba(255, 255, 255, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
        }

        #loading-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); z-index: 150;
            display: none; flex-direction: column; justify-content: center; align-items: center; color: white; font-weight: bold;
        }

        .spinner {
            border: 4px solid rgba(255,255,255,0.3); border-top: 4px solid #fff;
            border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin-bottom: 10px;
        }

        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        .scanner-laser {
            position: absolute; top: 0; left: 0; width: 100%; height: 4px;
            background-color: rgba(0, 255, 0, 0.8); box-shadow: 0 0 15px 5px rgba(0, 255, 0, 0.5);
            z-index: 120; display: none;
        }

        @keyframes scan-animation { 0% { top: 0%; } 50% { top: 100%; } 100% { top: 0%; } }

        @keyframes pop-in {
            0% { transform: translate(-50%, -50%) scale(0); }
            80% { transform: translate(-50%, -50%) scale(1.2); }
            100% { transform: translate(-50%, -50%) scale(1); }
        }

        .hotspot.pop { animation: pop-in 0.4s ease-out forwards, pulse 1.5s infinite; animation-delay: 0s, 0.4s; }

        .info-panel {
            position: absolute; bottom: 15px; right: 15px; width: 220px; padding: 15px;
            background-color: rgba(45, 45, 45, 0.85); backdrop-filter: blur(4px);
            border-radius: 10px; border-left: 4px solid #555; z-index: 50; box-shadow: 0 4px 8px rgba(0,0,0,0.5); display: none;
        }

        .info-panel h3 { margin: 0 0 8px 0; font-size: 14px; color: #fff; }
        .info-panel p { margin: 0; line-height: 1.4; color: #ddd; font-size: 12px; }
        
        .aviso {
            position: absolute; top: 10px; left: 50%; transform: translateX(-50%);
            z-index: 200; color: white; padding: 10px 15px; border-radius: 8px; display: none;
            text-align: center; width: 80%; font-size: 14px;
        }

        .aviso-erro { background: rgba(220, 53, 69, 0.9); }
        .aviso-sucesso { background: rgba(40, 167, 69, 0.9); }
    </style>
</head>
<body>

<div class="container">
    <div class="controls">
        <button id="btn-interest" data-mode="interesse">ℹ️ Pontos</button>
        <button id="btn-lube" data-mode="lubrificacao">💧 Lubrificação</button>
        <button id="btn-maint" data-mode="manutencao">🔧 Manutenção</button>
    </div>

    <div class="action-buttons">
        <button id="btn-scan" class="btn-action" style="background-color: #4CAF50; border-color: #4CAF50; color: white;">
            🤖 Escanear Torno
        </button>
        <!-- BOTÃO PARA RETOMAR A CÂMARA -->
        <button id="btn-resume" class="btn-action" style="background-color: #f44336; border-color: #f44336; color: white; display: none;">
            ▶️ Desbloquear Câmara
        </button>
        <button id="btn-save" class="btn-action" style="background-color: #007bff; border-color: #007bff; color: white; display: none;">
            💾 Guardar Ajuste
        </button>
        <button id="btn-upload" class="btn-action" style="background-color: #2b2b2b; color: white;">
            📸 Foto
        </button>
        <input type="file" id="image-upload" accept="image/*" style="display: none;">
    </div>

    <div class="camera-view" id="camera-view">
        <div id="msg-aviso" class="aviso aviso-erro"></div>
        <div class="scanner-laser" id="scanner-laser"></div>
        
        <div id="loading-overlay">
            <div class="spinner"></div>
            <span id="loading-text">A processar Torno Mecânico...</span>
        </div>
        
        <video id="webcam" autoplay playsinline></video>
        <img id="foto-estatica" alt="Visualização">
        
        <div class="info-panel" id="info-panel">
            <h3 id="info-title">Modo Selecionado</h3>
            <p id="info-desc">Clique nos pontos na tela para ajustar.</p>
        </div>
    </div>
</div>

<script>
    const apiKey = ""; // Chave do Gemini injetada automaticamente no ambiente
    
    const videoElement = document.getElementById('webcam');
    const msgAviso = document.getElementById('msg-aviso');
    const fotoEstatica = document.getElementById('foto-estatica');
    const loadingOverlay = document.getElementById('loading-overlay');

    // --- INICIALIZAÇÃO DA CÂMERA ---
    function mostrarAviso(texto, tipo = 'erro') {
        msgAviso.innerText = texto; msgAviso.className = `aviso aviso-${tipo}`;
        msgAviso.style.display = 'block'; setTimeout(() => { msgAviso.style.display = 'none'; }, 6000);
    }

    async function iniciarCamera() {
        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
                videoElement.srcObject = stream; videoElement.style.display = 'block'; fotoEstatica.style.display = 'none';
            } catch (err1) {
                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ video: true });
                    videoElement.srcObject = stream; videoElement.style.display = 'block'; fotoEstatica.style.display = 'none';
                } catch (err2) {
                    mostrarAviso("Nenhuma câmara encontrada.", "erro");
                }
            }
        }
    }
    iniciarCamera();

    // --- UPLOAD ---
    document.getElementById('btn-upload').addEventListener('click', () => document.getElementById('image-upload').click());
    document.getElementById('image-upload').addEventListener('change', function(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                if (videoElement.srcObject) videoElement.srcObject.getTracks().forEach(track => track.stop());
                videoElement.style.display = 'none'; fotoEstatica.src = e.target.result; fotoEstatica.style.display = 'block';
                document.getElementById('btn-resume').style.display = 'none';
                document.getElementById('btn-scan').style.display = 'flex';
                document.querySelectorAll('.hotspot').forEach(el => el.remove());
                escaneamentoConcluido = false;
            };
            reader.readAsDataURL(file);
        }
        event.target.value = '';
    });

    // --- BASE DE DADOS DOS PONTOS ---
    const pontosPadrao = [
        { id: "int1", tipo: "interesse", top: "45%", left: "15%", titulo: "Cabeçote Fixo", descricao: "Abriga motor e caixa de engrenagens." },
        { id: "int2", tipo: "interesse", top: "50%", left: "30%", titulo: "Placa", descricao: "Fixa a peça com segurança." },
        { id: "int3", tipo: "interesse", top: "45%", left: "60%", titulo: "Torre", descricao: "Prende a ferramenta de corte." },
        { id: "int4", tipo: "interesse", top: "75%", left: "55%", titulo: "Barramento", descricao: "Base rígida e guia." },
        { id: "int5", tipo: "interesse", top: "40%", left: "85%", titulo: "Cabeçote Móvel", descricao: "Apoia peças longas." },
        { id: "lube1", tipo: "lubrificacao", top: "60%", left: "45%", titulo: "Barramento", descricao: "Lubrificar guias diariamente." },
        { id: "lube2", tipo: "lubrificacao", top: "70%", left: "50%", titulo: "Fuso", descricao: "Aplicar óleo leve." },
        { id: "maint1", tipo: "manutencao", top: "30%", left: "20%", titulo: "Óleo", descricao: "Verificar visor." },
        { id: "maint2", tipo: "manutencao", top: "45%", left: "30%", titulo: "Placa", descricao: "Desmontar e limpar." }
    ];

    let pontos = JSON.parse(localStorage.getItem('calibracao_torno')) || pontosPadrao;
    let modoAtual = null;
    let escaneamentoConcluido = false;

    // --- RENDERIZAÇÃO ---
    function renderizarPontos() {
        document.querySelectorAll('.hotspot').forEach(el => el.remove());
        const cameraView = document.getElementById('camera-view');

        pontos.forEach(ponto => {
            if (ponto.visivel === false) return; // Só renderiza se a IA confirmou a presença da peça

            const div = document.createElement('div');
            div.className = 'hotspot'; div.dataset.type = ponto.tipo; div.dataset.id = ponto.id;
            div.style.top = ponto.top; div.style.left = ponto.left;
            
            // Adiciona a imagem/ícone dentro do ponto
            if (ponto.tipo === 'interesse') div.innerHTML = 'ℹ️';
            else if (ponto.tipo === 'lubrificacao') div.innerHTML = '💧';
            else if (ponto.tipo === 'manutencao') div.innerHTML = '🔧';
            
            let isDragging = false; let startX, startY, startLeft, startTop;

            const onPointerDown = (e) => {
                isDragging = false;
                const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                const clientY = e.touches ? e.touches[0].clientY : e.clientY;
                startX = clientX; startY = clientY;
                startLeft = div.offsetLeft; startTop = div.offsetTop;
                document.addEventListener('mousemove', onPointerMove); document.addEventListener('mouseup', onPointerUp);
                document.addEventListener('touchmove', onPointerMove, {passive: false}); document.addEventListener('touchend', onPointerUp);
            };

            const onPointerMove = (e) => {
                const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                const clientY = e.touches ? e.touches[0].clientY : e.clientY;
                const dx = clientX - startX; const dy = clientY - startY;
                if (Math.abs(dx) > 5 || Math.abs(dy) > 5) { isDragging = true; if (e.cancelable) e.preventDefault(); }
                if (isDragging) {
                    const rect = cameraView.getBoundingClientRect();
                    div.style.left = `${Math.max(0, Math.min(startLeft + dx, rect.width))}px`;
                    div.style.top = `${Math.max(0, Math.min(startTop + dy, rect.height))}px`;
                }
            };

            const onPointerUp = () => {
                document.removeEventListener('mousemove', onPointerMove); document.removeEventListener('mouseup', onPointerUp);
                document.removeEventListener('touchmove', onPointerMove); document.removeEventListener('touchend', onPointerUp);
                
                if (isDragging) {
                    const rect = cameraView.getBoundingClientRect();
                    const pontoAlvo = pontos.find(p => p.id === div.dataset.id);
                    if (pontoAlvo) {
                        pontoAlvo.top = ((div.offsetTop / rect.height) * 100).toFixed(2) + '%';
                        pontoAlvo.left = ((div.offsetLeft / rect.width) * 100).toFixed(2) + '%';
                    }
                    document.getElementById('btn-save').style.display = 'flex';
                }
            };

            div.addEventListener('mousedown', onPointerDown);
            div.addEventListener('touchstart', onPointerDown, {passive: true});
            div.addEventListener('click', (e) => {
                if (isDragging) return;
                const infoPanel = document.getElementById('info-panel');
                document.getElementById('info-title').textContent = ponto.titulo;
                document.getElementById('info-desc').textContent = ponto.descricao;
                if(ponto.tipo === 'interesse') infoPanel.style.borderLeftColor = 'var(--info-color)';
                if(ponto.tipo === 'lubrificacao') infoPanel.style.borderLeftColor = 'var(--lube-color)';
                if(ponto.tipo === 'manutencao') infoPanel.style.borderLeftColor = 'var(--maint-color)';
            });
            cameraView.appendChild(div);
        });
    }

    // --- INTELIGÊNCIA ARTIFICIAL E ESCANEAMENTO ---
    async function iniciarEscaneamento() {
        document.querySelectorAll('.hotspot').forEach(el => el.remove());
        escaneamentoConcluido = false;
        document.getElementById('scanner-laser').style.display = 'block';
        document.getElementById('scanner-laser').style.animation = 'scan-animation 1.5s linear infinite';
        mostrarAviso("A escancear com IA...", "sucesso");

        try {
            let base64Image = ""; let mimeType = "image/jpeg"; const canvas = document.createElement('canvas');
            
            const drawAndScale = (source, w, h) => {
                const MAX = 1024;
                if (w > MAX || h > MAX) {
                    if (w > h) { h *= MAX / w; w = MAX; } 
                    else { w *= MAX / h; h = MAX; }
                }
                canvas.width = w; canvas.height = h;
                canvas.getContext('2d').drawImage(source, 0, 0, w, h);
                return canvas.toDataURL('image/jpeg', 0.85); 
            };

            if (videoElement.style.display !== 'none' && videoElement.readyState >= 2) {
                base64Image = drawAndScale(videoElement, videoElement.videoWidth, videoElement.videoHeight);
            } else if (fotoEstatica.style.display !== 'none' && fotoEstatica.src) {
                if(fotoEstatica.src.startsWith('data:')) base64Image = fotoEstatica.src;
                else base64Image = drawAndScale(fotoEstatica, fotoEstatica.naturalWidth, fotoEstatica.naturalHeight);
            } else throw new Error("Sem imagem.");

            const payload = {
                contents: [{ role: "user", parts: [
                    { text: "Identifique as seguintes partes do torno mecânico na imagem: 'cabecote_fixo', 'placa', 'torre', 'barramento', 'cabecote_movel'. Retorne APENAS as peças visíveis. Indique a posição central com 'top' e 'left' em percentagem (ex: '50%')." },
                    { inlineData: { mimeType: mimeType || "image/jpeg", data: base64Image.split(',')[1] } }
                ]}],
                generationConfig: { responseMimeType: "application/json", responseSchema: {
                    type: "ARRAY", items: { type: "OBJECT", properties: { 
                        id: { type: "STRING", description: "Um destes: cabecote_fixo, placa, torre, barramento, cabecote_movel" }, 
                        top: { type: "STRING", description: "Ex: 45%" }, 
                        left: { type: "STRING", description: "Ex: 60%" } 
                    } }
                }}
            };

            const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
            });
            const result = await response.json();
            
            pontos.forEach(p => p.visivel = false);
            const mapaPecas = { "cabecote_fixo": ["int1", "maint1"], "placa": ["int2", "maint2"], "torre": ["int3"], "barramento": ["int4", "lube1", "lube2"], "cabecote_movel": ["int5"] };
            
            let jsonText = result.candidates[0].content.parts[0].text;
            const pecasEncontradas = JSON.parse(jsonText);
            
            if(pecasEncontradas.length === 0) {
                mostrarAviso("Nenhuma peça principal reconhecida nesta imagem.", "erro");
            } else {
                pecasEncontradas.forEach(peca => {
                    if (mapaPecas[peca.id]) {
                        mapaPecas[peca.id].forEach(id => {
                            const pt = pontos.find(p => p.id === id);
                            if (pt) { 
                                let valTop = peca.top.toString(); let valLeft = peca.left.toString();
                                if(!valTop.includes('%')) valTop += '%'; if(!valLeft.includes('%')) valLeft += '%';
                                pt.top = valTop; pt.left = valLeft; pt.visivel = true; 
                            }
                        });
                    }
                });
            }
        } catch (error) {
            console.error("Erro na IA:", error);
            mostrarAviso("A IA teve dificuldade em ler a imagem. Tente de outro ângulo.", "erro");
        } finally {
            document.getElementById('scanner-laser').style.display = 'none';
            escaneamentoConcluido = true;
            
            // --- CONGELA O VÍDEO PARA OS PONTOS NÃO MEXEREM MAIS! ---
            if (videoElement.style.display !== 'none') {
                videoElement.pause(); 
            }
            // Troca os botões
            document.getElementById('btn-scan').style.display = 'none';
            document.getElementById('btn-resume').style.display = 'flex';
            
            renderizarPontos();
            document.querySelectorAll('.hotspot').forEach(p => { p.classList.add('pop'); });
            
            modoAtual = 'interesse'; 
            document.querySelectorAll('.controls button').forEach(b => b.classList.remove('active'));
            document.getElementById('btn-interest').classList.add('active');
            document.querySelectorAll('.hotspot').forEach(ponto => {
                ponto.classList.toggle('visible', ponto.dataset.type === modoAtual);
            });

            document.getElementById('info-panel').style.display = 'block';
            document.getElementById('info-title').textContent = "Inspecionar Peças";
            document.getElementById('info-desc').textContent = "A imagem foi congelada para melhor precisão. Pode clicar nos pontos para ver os detalhes.";
            document.getElementById('info-panel').style.borderLeftColor = 'var(--info-color)';
        }
    }

    // --- EVENTOS E CONTROLOS ---
    document.getElementById('btn-scan').addEventListener('click', iniciarEscaneamento);
    
    // Retoma o vídeo ao vivo e esconde os pontos
    document.getElementById('btn-resume').addEventListener('click', () => {
        if (videoElement.style.display !== 'none') {
            videoElement.play();
        }
        document.querySelectorAll('.hotspot').forEach(el => el.remove());
        document.getElementById('btn-scan').style.display = 'flex';
        document.getElementById('btn-resume').style.display = 'none';
        document.getElementById('btn-save').style.display = 'none';
        document.getElementById('info-panel').style.display = 'none';
        escaneamentoConcluido = false;
        mostrarAviso("Câmara retomada. Aponte para um novo ângulo e escaneie novamente.", "sucesso");
    });

    document.getElementById('btn-save').addEventListener('click', () => {
        localStorage.setItem('calibracao_torno', JSON.stringify(pontos));
        mostrarAviso("Posições guardadas para este ângulo!", "sucesso");
        document.getElementById('btn-save').style.display = 'none';
    });

    function setModo(modo) {
        if (!escaneamentoConcluido) return mostrarAviso("Clique em 'Escanear Torno' primeiro.", "erro");
        modoAtual = (modoAtual === modo) ? null : modo;
        document.getElementById('btn-interest').classList.toggle('active', modoAtual === 'interesse');
        document.getElementById('btn-lube').classList.toggle('active', modoAtual === 'lubrificacao');
        document.getElementById('btn-maint').classList.toggle('active', modoAtual === 'manutencao');

        const p = document.getElementById('info-panel');
        if (!modoAtual) { p.style.borderLeftColor = '#4CAF50'; document.getElementById('info-title').textContent = "Visão Geral"; document.getElementById('info-desc').textContent = "Todos os pontos ativos."; }
        else if (modoAtual === 'interesse') { p.style.borderLeftColor = 'var(--info-color)'; document.getElementById('info-title').textContent = "Pontos de Interesse"; }
        else if (modoAtual === 'lubrificacao') { p.style.borderLeftColor = 'var(--lube-color)'; document.getElementById('info-title').textContent = "Lubrificação"; }
        else { p.style.borderLeftColor = 'var(--maint-color)'; document.getElementById('info-title').textContent = "Manutenção"; }

        document.querySelectorAll('.hotspot').forEach(ponto => {
            ponto.classList.remove('pop');
            ponto.classList.toggle('visible', !modoAtual || ponto.dataset.type === modoAtual);
        });
    }

    document.getElementById('btn-interest').addEventListener('click', () => setModo('interesse'));
    document.getElementById('btn-lube').addEventListener('click', () => setModo('lubrificacao'));
    document.getElementById('btn-maint').addEventListener('click', () => setModo('manutencao'));
</script>

</body>
</html>
